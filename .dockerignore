# ============================================
# Sakura AI - Docker 构建排除文件
# ============================================
# 此文件定义了在 Docker 构建时不需要复制到镜像的文件和目录
# 减小构建上下文，加快构建速度

# ============================================
# Node.js 依赖和缓存
# ============================================
node_modules
npm-debug.log
yarn-error.log
yarn-debug.log*
package-lock.json.bak
.npm
.yarn

# ============================================
# 构建产物（会在容器内重新构建）
# ============================================
dist
build
.next
out

# ============================================
# Git 相关
# ============================================
.git
.gitignore
.gitattributes
.github

# ============================================
# 开发工具配置
# ============================================
.vscode
.cursor
.claude
.bolt
.codebuddy
.kiro
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# 测试相关
# ============================================
tests
*.test.js
*.test.ts
*.spec.js
*.spec.ts
coverage
.nyc_output
test-results

# ============================================
# 日志文件
# ============================================
logs
*.log
npm-debug.log*

# ============================================
# 运行时数据和临时文件
# ============================================
artifacts
screenshots
midscene_run
uploads
temp
tmp
backups
.cache
.openclaw

# ============================================
# 环境变量（使用 docker-compose 传递）
# ============================================
.env
.env.*
.env.local
.env.*.local
.env.production
.env.development
.env.performance
# 保留 .env.example 用于在容器中创建默认 .env
!.env.example

# ============================================
# 文档和说明
# ============================================
docs
*.md
!README.md
CHANGELOG.md
LICENSE

# ============================================
# Docker 相关
# ============================================
Dockerfile*
docker-compose*.yml
.dockerignore

# ============================================
# CI/CD
# ============================================
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# ============================================
# 项目特定文件
# ============================================
# 原型文件
prototypes

# 任务文件
tasks
tasks_data

# 提交日志
commit

# 备份文件
*.backup

# 其他
.hintrc
*.pid
*.seed
*.pid.lock
